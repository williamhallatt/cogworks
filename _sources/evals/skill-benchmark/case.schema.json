{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cogworks.dev/evals/skill-benchmark/case.schema.json",
  "title": "Skill Benchmark Case",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "case_id",
    "title",
    "category",
    "task_prompt",
    "expected_activation",
    "observable_checks"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "case_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,127}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "enum": [
        "invoked-task",
        "hard-negative",
        "boundary"
      ]
    },
    "task_prompt": {
      "type": "string",
      "minLength": 1
    },
    "expected_activation": {
      "type": "string",
      "enum": [
        "must_activate",
        "may_activate",
        "must_not_activate"
      ]
    },
    "allowed_tools": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "default": []
    },
    "forbidden_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "default": []
    },
    "observable_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/observableCheck"
      }
    },
    "rubric_dimensions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rubricDimension"
      },
      "default": []
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "default": []
    },
    "notes": {
      "type": [
        "string",
        "null"
      ],
      "default": null
    }
  },
  "$defs": {
    "observableCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "weight"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,63}$"
        },
        "kind": {
          "type": "string",
          "enum": [
            "file_exists",
            "file_contains",
            "file_not_contains",
            "tool_called",
            "tool_not_called",
            "command_called",
            "command_not_called",
            "json_field_equals",
            "state_assertion",
            "judge_only"
          ]
        },
        "target": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "value": {
          "type": [
            "string",
            "number",
            "boolean",
            "null"
          ],
          "default": null
        },
        "weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "required": {
          "type": "boolean",
          "default": true
        },
        "notes": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      }
    },
    "rubricDimension": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "weight"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,63}$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
