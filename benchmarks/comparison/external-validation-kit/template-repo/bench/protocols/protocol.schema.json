{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/skill-benchmark/protocol.schema.json",
  "title": "Benchmark Protocol",
  "type": "object",
  "required": [
    "name",
    "source_manifest",
    "tasks",
    "model_family",
    "budget",
    "pipelines",
    "execution",
    "reproducibility"
  ],
  "properties": {
    "name": {"type": "string", "minLength": 1},
    "source_manifest": {"type": "string", "minLength": 1},
    "tasks": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1
    },
    "model_family": {"type": "string", "minLength": 1},
    "budget": {
      "type": "object",
      "required": ["max_total_tokens", "max_context_tokens", "max_runtime_sec"],
      "properties": {
        "max_total_tokens": {"type": "integer", "minimum": 1},
        "max_context_tokens": {"type": "integer", "minimum": 1},
        "max_runtime_sec": {"type": "integer", "minimum": 1}
      }
    },
    "pipelines": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["generation_command_template", "skill_path_template", "execution_mode"],
        "properties": {
          "generation_command_template": {"type": "string", "minLength": 1},
          "skill_path_template": {"type": "string", "minLength": 1},
          "execution_mode": {"enum": ["skill_installed", "protocol_prompt"]},
          "skill_install": {
            "type": "object",
            "required": ["source", "agent", "expected_skills", "install_flags"],
            "properties": {
              "source": {"type": "string", "minLength": 1},
              "agent": {"const": "codex"},
              "expected_skills": {
                "type": "array",
                "items": {"type": "string", "minLength": 1}
              },
              "install_flags": {
                "type": "array",
                "items": {"type": "string", "minLength": 1}
              }
            }
          },
          "skill_invocation": {
            "type": "object",
            "required": ["required_skill_slug", "evidence_markers"],
            "properties": {
              "required_skill_slug": {"type": "string", "minLength": 1},
              "evidence_markers": {
                "type": "array",
                "items": {"type": "string", "minLength": 1}
              }
            }
          },
          "notes": {"type": "string"}
        },
        "allOf": [
          {
            "if": {"properties": {"execution_mode": {"const": "skill_installed"}}},
            "then": {"required": ["skill_install", "skill_invocation"]}
          }
        ]
      }
    },
    "execution": {
      "type": "object",
      "required": ["isolation_mode", "allowed_mounts", "forbidden_paths"],
      "properties": {
        "isolation_mode": {"const": "ephemeral_container"},
        "allowed_mounts": {"type": "array", "items": {"type": "string"}},
        "forbidden_paths": {"type": "array", "items": {"type": "string"}}
      }
    },
    "reproducibility": {
      "type": "object",
      "required": ["repeats_min"],
      "properties": {
        "repeats_min": {"type": "integer", "minimum": 1}
      }
    }
  }
}
