{
  "name": "protocol-hard-v2",
  "source_manifest": "benchmarks/comparison/datasets/pipeline-benchmark/manifest.jsonl",
  "tasks": [
    "pb-001-api-auth",
    "pb-002-k8s-troubleshoot",
    "pb-003-deployment-workflow",
    "pb-004-testing-patterns",
    "pb-005-auth-token-rotation-incident",
    "pb-006-k8s-multi-cause-outage",
    "pb-007-zero-downtime-db-migration",
    "pb-008-third-party-api-degradation",
    "pb-009-secrets-rotation-across-envs",
    "pb-010-oncall-triage-playbook"
  ],
  "model_family": "gpt-5-codex",
  "budget": {
    "max_total_tokens": 20000,
    "max_context_tokens": 8000,
    "max_runtime_sec": 1200
  },
  "pipelines": {
    "cogworks": {
      "generation_command_template": "bash benchmarks/comparison/scripts/run-protocol-generator.sh cogworks '{task_id}' '{sources_path}' '{skill_out_dir}'",
      "skill_path_template": "{out_dir}/generated-skill",
      "notes": "Cogworks protocol execution in non-interactive mode."
    },
    "generator-a": {
      "generation_command_template": "bash benchmarks/comparison/scripts/run-protocol-generator.sh generator-a '{task_id}' '{sources_path}' '{skill_out_dir}'",
      "skill_path_template": "{out_dir}/generated-skill",
      "notes": "Workflow comparator adapted to single-pass protocol execution."
    },
    "generator-b": {
      "generation_command_template": "bash benchmarks/comparison/scripts/run-protocol-generator.sh generator-b '{task_id}' '{sources_path}' '{skill_out_dir}'",
      "skill_path_template": "{out_dir}/generated-skill",
      "notes": "Process comparator adapted to single-pass protocol execution."
    }
  }
}
