# Test results (deep, ephemeral, regenerated by framework)
tests/results/**/
!tests/results/.gitkeep

# Generated smoke / benchmark artifacts (non-canonical, scratch by default)
.cogworks-runs/**
!.cogworks-runs/README.md
tmp-agentic-output/**
!tmp-agentic-output/README.md

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Generated skills staging (installed to agents via npx skills add)
_generated-skills/

# Benchmark run output (generated skills, not canonical sources)
benchmarks/**/output_skills/

# Benchmark results (ephemeral, regenerated by benchmark runs)
benchmarks/comparison/results/**/
!benchmarks/comparison/results/.gitkeep

# Agent skill install targets (managed by npx skills add, not tracked in repo)
.agents/skills/
.claude/skills/
skills-lock.json

# OS files
.DS_Store
Thumbs.db
# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream
