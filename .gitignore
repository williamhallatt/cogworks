# Test results (deep, ephemeral, regenerated by framework)
tests/results/**/
!tests/results/.gitkeep

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Generated skills staging (installed to agents via npx skills add)
_generated-skills/

# Benchmark run output (generated skills, not canonical sources)
benchmarks/**/output_skills/

# Agent skill install targets (managed by npx skills add, not tracked in repo)
.agents/skills/
.claude/skills/

# OS files
.DS_Store
Thumbs.db
